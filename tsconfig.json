{
	"compilerOptions": {
		"strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "checkJs": true,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,

    "lib": ["ES2022", "dom"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "ignoreDeprecations": "6.0"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "**/__tests__/*"]
}
