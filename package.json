{
  "name": "astronomical",
  "version": "3.0.7",
  "type": "commonjs",
  "description": "offers a way to query a Javascript AST to find specific patterns using a syntax somewhat similar to XPath.",
  "sideEffects": false,
  "scripts": {
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "watch": "tsup --watch",
    "check": "npm run lint && npm run typecheck",
    "testWatch": "node --import tsx --test --watch tests/**/*.test.ts",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "bench": "node bench/run.js",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RetireJS/ASTronomical.git"
  },
  "author": "Erlend Oftedal <erlend@oftedal.no>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "expect": "^30.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "meriyah": "^7.1.0"
  },
  "files": [
    "lib/**/*"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    }
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js"
}
